{
  "name": "printpro-desktop",
  "version": "0.1.0",
  "description": "PrintPro — коробочная версия: устанавливается одним кликом, база данных встроена. Обёртка (Electron) вокруг printpro-api + printpro-web — код этих двух приложений НЕ дублируется.",
  "private": true,
  "author": "DushanbePrint",
  "license": "UNLICENSED",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.4",
    "electron-store": "8.2.0",
    "embedded-postgres": "17.10.0-beta.17"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dushanbeprint.printpro",
    "productName": "PrintPro",
    "copyright": "© DushanbePrint",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "backup.js",
      "setup.html",
      "setup.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../printpro-api/dist",
        "to": "printpro-api/dist"
      },
      {
        "from": "../printpro-api/prisma/schema.prisma",
        "to": "printpro-api/prisma/schema.prisma"
      },
      {
        "from": "../printpro-api/prisma/migrations",
        "to": "printpro-api/prisma/migrations"
      },
      {
        "from": "../printpro-api/node_modules/.prisma",
        "to": "printpro-api/node_modules/.prisma"
      },
      {
        "from": "../printpro-api/node_modules/@prisma/client",
        "to": "printpro-api/node_modules/@prisma/client"
      },
      {
        "from": "../printpro-api/node_modules/prisma",
        "to": "printpro-api/node_modules/prisma"
      },
      {
        "from": "../printpro-api/node_modules",
        "to": "printpro-api/node_modules"
      },
      {
        "from": "../printpro-web/.next/standalone",
        "to": "printpro-web"
      },
      {
        "from": "../printpro-web/.next/static",
        "to": "printpro-web/.next/static"
      },
      {
        "from": "../printpro-web/public",
        "to": "printpro-web/public"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/.prisma/**",
      "**/@prisma/client/**",
      "**/node_modules/prisma/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  }
}
