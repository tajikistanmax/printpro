{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/integration/**/*.int-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/test/integration/_env.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1
}
