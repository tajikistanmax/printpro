// PrintPro — схема базы данных
// Бисмиллахир Рахмони Рахим
// Стек: NestJS + Prisma + PostgreSQL. Мультитенантный, offline-first.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS (справочники типов) =======================

enum PricingType {
  FIXED // фиксированная цена
  QUANTITY_TIER // по тиражу (визитки)
  BY_SIZE // по размеру/формату (фото)
  BY_AREA // по площади м² (баннеры)
  MANUAL // договорная — цена при приёме (ремонт, восстановление, реставрация)
}

enum OrderType {
  SALE // продажа товара
  PRINT // печать / дизайн
  REPAIR // ремонт принтеров
  RECOVERY // восстановление данных
}

enum OrderStatus {
  ACCEPTED // принят
  IN_PROGRESS // в работе
  READY // готов
  DELIVERED // выдан
  CANCELLED // отменён
}

enum PaymentStatus {
  UNPAID // не оплачен
  PARTIAL // оплачен частично
  PAID // оплачен полностью
  DEBT // в долг
}

enum PaymentMethod {
  CASH // наличные
  CARD // карта
  TRANSFER // перевод
  DEBT // в долг
}

enum StockMovementType {
  IN // приход
  OUT // расход (продажа)
  WRITE_OFF // списание
  ADJUST // корректировка
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ProductionStatus {
  PENDING // ожидает
  PRINTING // печать
  CUTTING // резка
  BINDING // брошюровка/переплёт
  PACKAGING // упаковка
  COMPLETED // готово
  CANCELLED // отменено
}

enum ProofStatus {
  TODO // нужно создать
  IN_PROGRESS // в работе
  SENT // отправлен клиенту
  REVISION // требует правки
  APPROVED // согласован
  REJECTED // отклонён
}

enum SalaryType {
  MONTHLY // оклад
  HOURLY // почасовая
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum ClientType {
  INDIVIDUAL // физическое лицо
  COMPANY // компания
  REGULAR // постоянный
  VIP // VIP
}

enum OrderUrgency {
  NORMAL // обычный
  URGENT // срочный
  EXPRESS // очень срочный (экспресс)
}

// ======================= ТЕНАНТ И ПОЛЬЗОВАТЕЛИ =======================

model Company {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  name      String
  currency  String    @default("TJS")
  language  String    @default("ru")
  createdAt DateTime  @default(now())

  branches          Branch[]
  users             User[]
  roles             Role[]
  clients           Client[]
  serviceCategories ServiceCategory[]
  services          Service[]
  productCategories ProductCategory[]
  units             Unit[]
  products          Product[]
  suppliers         Supplier[]
  orders            Order[]
  tasks             Task[]
  settings          Setting[]
}

model Branch {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  address   String?
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  users          User[]
  stock          Stock[]
  orders         Order[]
  cashShifts     CashShift[]
  stockMovements StockMovement[]
  stockReceipts  StockReceipt[]
}

model Role {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  isSystem  Boolean   @default(false)

  users       User[]
  permissions RolePermission[]
}

model Permission {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  code      String    @unique // например orders.view
  label     String
  group     String?

  roles RolePermission[]
}

model RolePermission {
  // --- синхронизация ---
  updatedAt    DateTime   @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  // --- синхронизация ---
  updatedAt    DateTime   @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  roleId       String?
  role         Role?      @relation(fields: [roleId], references: [id])
  login        String
  passwordHash String
  fullName     String
  phone        String?
  position     String? // должность
  salaryType   SalaryType @default(MONTHLY)
  rate         Decimal    @default(0) @db.Decimal(12, 2) // оклад или ставка/час
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  ordersCreated  Order[]          @relation("OrderCreatedBy")
  ordersAssigned Order[]          @relation("OrderAssignedTo")
  ordersDesigned Order[]          @relation("OrderDesigner")
  ordersOperated Order[]          @relation("OrderOperator")
  tasksCreated   Task[]           @relation("TaskCreatedBy")
  tasksAssigned  Task[]           @relation("TaskAssignedTo")
  payments       Payment[]
  stockMovements StockMovement[]
  cashShifts     CashShift[]
  productionJobs ProductionJob[]  @relation("ProductionAssignee")
  designProofs   DesignProof[]    @relation("DesignProofAssignee")
  workTime       WorkTimeRecord[]
  advances       SalaryAdvance[]
  salaryRecords  SalaryRecord[]

  @@unique([companyId, login])
}

// ======================= КЛИЕНТЫ =======================

model Client {
  id        String     @id @default(uuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  fullName  String?
  phone     String
  type      ClientType @default(INDIVIDUAL)
  email     String?
  address   String?
  inn       String?
  discount  Decimal    @default(0) @db.Decimal(5, 2) // скидка, %
  note      String?
  createdAt DateTime   @default(now())
  // --- синхронизация ---
  updatedAt DateTime   @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?

  orders Order[]
  debts  ClientDebt[]

  @@index([companyId, phone])
  @@index([companyId, updatedAt])
}

// ======================= УСЛУГИ =======================

model ServiceCategory {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  sortOrder Int       @default(0)

  services Service[]
}

model Service {
  // --- синхронизация ---
  updatedAt       DateTime         @default(now()) @updatedAt
  deletedAt       DateTime?
  syncNode        String?
  id              String           @id @default(uuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  categoryId      String?
  category        ServiceCategory? @relation(fields: [categoryId], references: [id])
  name            String
  pricingType     PricingType      @default(FIXED)
  basePrice       Decimal          @default(0) @db.Decimal(12, 2)
  costPrice       Decimal          @default(0) @db.Decimal(12, 2) // себестоимость (для прибыли)
  leadTimeMin     Int? // время выполнения, минут
  designSurcharge Decimal          @default(0) @db.Decimal(12, 2)
  minQuantity     Int              @default(1)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())

  priceTiers ServicePriceTier[]
  sizes      ServiceSize[]
  options    ServiceOption[]
  orderItems OrderItem[]
}

model ServicePriceTier {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  minQty    Int
  maxQty    Int?
  price     Decimal   @db.Decimal(12, 2)
}

model ServiceSize {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  label     String // например 10x15, A4
  price     Decimal   @db.Decimal(12, 2)
}

model ServiceOption {
  // --- синхронизация ---
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?
  syncNode      String?
  id            String    @id @default(uuid())
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name          String // тип бумаги, срочность
  priceModifier Decimal   @default(0) @db.Decimal(12, 2)
}

// ======================= ТОВАРЫ И СКЛАД =======================

model ProductCategory {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String

  products Product[]
}

model Unit {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String // штука, рулон, метр квадратный
  shortName String // шт, рул, м²

  products Product[]
}

model Product {
  // --- синхронизация ---
  updatedAt  DateTime         @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String           @id @default(uuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id])
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  unitId     String?
  unit       Unit?            @relation(fields: [unitId], references: [id])
  name       String
  salePrice  Decimal          @default(0) @db.Decimal(12, 2)
  minStock   Decimal          @default(0) @db.Decimal(12, 3) // порог оповещения
  barcode    String?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())

  stock        Stock[]
  movements    StockMovement[]
  orderItems   OrderItem[]
  receiptItems StockReceiptItem[]
}

model Stock {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id])
  quantity  Decimal   @default(0) @db.Decimal(12, 3)

  @@unique([productId, branchId])
}

model StockMovement {
  // --- синхронизация ---
  updatedAt DateTime          @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String            @id @default(uuid())
  companyId String
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  branchId  String?
  branch    Branch?           @relation(fields: [branchId], references: [id])
  type      StockMovementType
  quantity  Decimal           @db.Decimal(12, 3)
  reason    String?
  orderId   String?
  order     Order?            @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?             @relation(fields: [userId], references: [id])
  createdAt DateTime          @default(now())
}

model Supplier {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  phone     String?
  note      String?

  receipts StockReceipt[]
}

model StockReceipt {
  // --- синхронизация ---
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String    @id @default(uuid())
  companyId  String
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  branchId   String?
  branch     Branch?   @relation(fields: [branchId], references: [id])
  date       DateTime  @default(now())
  note       String?

  items StockReceiptItem[]
}

model StockReceiptItem {
  // --- синхронизация ---
  updatedAt DateTime     @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String       @id @default(uuid())
  receiptId String
  receipt   StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Decimal      @db.Decimal(12, 3)
  cost      Decimal      @default(0) @db.Decimal(12, 2)
}

// ======================= ЗАКАЗЫ =======================

model Order {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  orderNumber    String
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  orderType      OrderType
  status         OrderStatus   @default(ACCEPTED)
  paymentStatus  PaymentStatus @default(UNPAID)
  assignedUserId String?
  assignedUser   User?         @relation("OrderAssignedTo", fields: [assignedUserId], references: [id])
  createdById    String?
  createdBy      User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  designerId     String?
  designer       User?         @relation("OrderDesigner", fields: [designerId], references: [id])
  operatorId     String?
  operator       User?         @relation("OrderOperator", fields: [operatorId], references: [id])
  format         String? // формат: A4, A3, баннер 1x2м...
  colorMode      String? // цветность: цветной / ч-б
  urgency        OrderUrgency  @default(NORMAL)
  deadline       DateTime?
  total          Decimal       @default(0) @db.Decimal(12, 2)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime      @default(now())
  // --- синхронизация ---
  updatedAt      DateTime      @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?

  items          OrderItem[]
  repairDetail   OrderRepairDetail?
  recoveryDetail OrderRecoveryDetail?
  files          OrderFile[]
  payments       Payment[]
  debts          ClientDebt[]
  tasks          Task[]
  stockMovements StockMovement[]
  productionJobs ProductionJob[]
  proofs         DesignProof[]

  @@unique([companyId, orderNumber])
  @@index([companyId, updatedAt])
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType    ItemType
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal   @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  unitCost    Decimal   @default(0) @db.Decimal(12, 2) // себестоимость за единицу (снимок)
  options     Json? // выбранные опции/размер/тип бумаги
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
  lineCost    Decimal   @default(0) @db.Decimal(12, 2) // себестоимость строки
  // --- синхронизация ---
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
}

model OrderRepairDetail {
  // --- синхронизация ---
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
  id          String    @id @default(uuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deviceModel String?
  problem     String?
  diagnosis   String?
}

model OrderRecoveryDetail {
  // --- синхронизация ---
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?
  syncNode      String?
  id            String    @id @default(uuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deviceType    String? // HDD, SSD, USB, карта памяти
  mediaModel    String?
  whatToRecover String?
}

model OrderFile {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileName  String?
  type      String?
  createdAt DateTime  @default(now())
}

// ======================= КАССА И ДЕНЬГИ =======================

model CashShift {
  // --- синхронизация ---
  updatedAt      DateTime  @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String    @id @default(uuid())
  companyId      String
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)

  payments  Payment[]
  movements CashMovement[]
}

model Payment {
  id        String        @id @default(uuid())
  companyId String
  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id])
  shiftId   String?
  shift     CashShift?    @relation(fields: [shiftId], references: [id])
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  createdAt DateTime      @default(now())
  // --- синхронизация ---
  updatedAt DateTime      @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?

  @@index([companyId, updatedAt])
}

model CashMovement {
  // --- синхронизация ---
  updatedAt DateTime   @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String     @id @default(uuid())
  companyId String
  shiftId   String?
  shift     CashShift? @relation(fields: [shiftId], references: [id])
  type      String // IN / OUT
  amount    Decimal    @db.Decimal(12, 2)
  reason    String?
  createdAt DateTime   @default(now())
}

model ClientDebt {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  orderId   String?
  order     Order?    @relation(fields: [orderId], references: [id])
  amount    Decimal   @db.Decimal(12, 2)
  dueDate   DateTime?
  isClosed  Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// ======================= ЗАДАЧИ =======================

model Task {
  // --- синхронизация ---
  updatedAt      DateTime   @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String     @id @default(uuid())
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id])
  title          String
  description    String?
  clientPhone    String?
  orderId        String?
  order          Order?     @relation(fields: [orderId], references: [id])
  assignedUserId String?
  assignedUser   User?      @relation("TaskAssignedTo", fields: [assignedUserId], references: [id])
  createdById    String?
  createdBy      User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  dueDate        DateTime?
  status         TaskStatus @default(NEW)
  priority       Int        @default(0)
  createdAt      DateTime   @default(now())
}

// ======================= ПРОИЗВОДСТВО =======================

model ProductionJob {
  // --- синхронизация ---
  updatedAt      DateTime         @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String           @id @default(uuid())
  companyId      String
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         ProductionStatus @default(PENDING)
  assignedUserId String?
  assignedUser   User?            @relation("ProductionAssignee", fields: [assignedUserId], references: [id])
  printer        String? // назначенный принтер/станок
  priority       Int              @default(0)
  note           String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([companyId, status])
}

// ======================= ДИЗАЙН-МАКЕТЫ =======================

model DesignProof {
  // --- синхронизация ---
  deletedAt      DateTime?
  syncNode       String?
  id             String      @id @default(uuid())
  companyId      String
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title          String?
  version        Int         @default(1)
  status         ProofStatus @default(TODO)
  fileUrl        String?
  fileName       String?
  comment        String? // комментарий клиента/правки
  assignedUserId String?
  assignedUser   User?       @relation("DesignProofAssignee", fields: [assignedUserId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyId, status])
}

// ======================= ЗАРПЛАТА =======================

model WorkTimeRecord {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @default(now())
  hours     Decimal   @db.Decimal(6, 2)
  note      String?

  @@index([companyId, userId])
}

model PayrollPeriod {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean   @default(false)
  createdAt DateTime  @default(now())

  records SalaryRecord[]
}

model SalaryAdvance {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal   @db.Decimal(12, 2)
  date      DateTime  @default(now())
  note      String?
}

model SalaryRecord {
  // --- синхронизация ---
  updatedAt DateTime      @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String        @id @default(uuid())
  companyId String
  periodId  String
  period    PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  base      Decimal       @default(0) @db.Decimal(12, 2)
  bonus     Decimal       @default(0) @db.Decimal(12, 2)
  advance   Decimal       @default(0) @db.Decimal(12, 2)
  deduction Decimal       @default(0) @db.Decimal(12, 2)
  total     Decimal       @default(0) @db.Decimal(12, 2)
  isPaid    Boolean       @default(false)

  @@unique([periodId, userId])
}

// ======================= СИНХРОНИЗАЦИЯ =======================

// На каком моменте остановилась синхронизация с другим узлом.
// peer — идентификатор другого узла (например "cloud" или "branch-1").
model SyncCursor {
  id         String   @id @default(uuid())
  peer       String   @unique
  lastPullAt DateTime @default(now()) // последняя забранная метка времени
  updatedAt  DateTime @updatedAt
}

// ======================= СИСТЕМНОЕ =======================

model AuditLog {
  id        String   @id @default(uuid())
  companyId String?
  userId    String?
  action    String
  entity    String?
  entityId  String?
  data      Json?
  createdAt DateTime @default(now())
}

model Setting {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  key       String
  value     String?

  @@unique([companyId, key])
}
