// PrintPro — схема базы данных
// Бисмиллахир Рахмони Рахим
// Стек: NestJS + Prisma + PostgreSQL. Мультитенантный, offline-first.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS (справочники типов) =======================

enum PricingType {
  FIXED // фиксированная цена
  QUANTITY_TIER // по тиражу (визитки)
  BY_SIZE // по размеру/формату (фото)
  BY_AREA // по площади м² (баннеры)
  MANUAL // договорная — цена при приёме (ремонт, восстановление, реставрация)
}

enum OrderType {
  SALE // продажа товара
  PRINT // печать / дизайн
  REPAIR // ремонт принтеров
  RECOVERY // восстановление данных
}

enum OrderStatus {
  ACCEPTED // принят / новый
  AWAITING_DESIGN // ожидает макет
  IN_DESIGN // в дизайне
  DESIGN_APPROVAL // макет на согласовании
  DESIGN_APPROVED // согласован
  IN_PROGRESS // в производстве
  READY // готов
  DELIVERED // выдан
  REWORK // возврат / переделка
  CANCELLED // отменён
}

enum PaymentStatus {
  UNPAID // не оплачен
  PARTIAL // оплачен частично
  PAID // оплачен полностью
  DEBT // в долг
}

enum PaymentMethod {
  CASH // наличные
  CARD // карта
  QR // оплата по QR-коду
  TRANSFER // перевод
  DEBT // в долг
}

enum StockMovementType {
  IN // приход
  OUT // расход (продажа)
  WRITE_OFF // списание
  ADJUST // корректировка
  RETURN // возврат от клиента (приход обратно)
}

enum ReceiptPaymentStatus {
  PAID // оплачено поставщику
  PARTIAL // частично
  DEBT // в долг
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ProductionStatus {
  PENDING // ожидает
  PRINTING // печать
  CUTTING // резка
  BINDING // брошюровка/переплёт
  PACKAGING // упаковка
  PAUSED // на паузе
  COMPLETED // готово
  REWORK // брак / переделка
  CANCELLED // отменено
}

enum ProofStatus {
  TODO // нужно создать
  IN_PROGRESS // в работе
  SENT // отправлен клиенту
  REVISION // требует правки
  APPROVED // согласован
  REJECTED // отклонён
}

enum SalaryType {
  MONTHLY // оклад
  HOURLY // почасовая
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum ClientType {
  INDIVIDUAL // физическое лицо
  COMPANY // компания
  REGULAR // постоянный
  VIP // VIP
}

enum OrderUrgency {
  NORMAL // обычный
  URGENT // срочный
  EXPRESS // очень срочный (экспресс)
}

enum EquipmentStatus {
  ACTIVE // работает
  REPAIR // на ремонте
  OFF // выключено / не используется
}

enum QuoteStatus {
  DRAFT // черновик
  SENT // отправлено клиенту
  ACCEPTED // принято (→ заказ)
  REJECTED // отклонено
}

enum DiscountType {
  PERCENT // процент
  FIXED // фиксированная сумма
}

enum ComplaintStatus {
  OPEN // зарегистрирована
  IN_REVIEW // на рассмотрении
  RESOLVED // решена
  REJECTED // отклонена
  CLOSED // закрыта
}

// ======================= ТЕНАНТ И ПОЛЬЗОВАТЕЛИ =======================

model Company {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  name      String
  currency  String    @default("TJS")
  language  String    @default("ru")
  createdAt DateTime  @default(now())

  branches          Branch[]
  users             User[]
  roles             Role[]
  clients           Client[]
  serviceCategories ServiceCategory[]
  services          Service[]
  productCategories ProductCategory[]
  units             Unit[]
  products          Product[]
  suppliers         Supplier[]
  orders            Order[]
  tasks             Task[]
  settings          Setting[]
  equipment         Equipment[]
  quotes            Quote[]
  promoCodes        PromoCode[]
  complaints        Complaint[]
}

model Branch {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  address   String?
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  users          User[]
  stock          Stock[]
  orders         Order[]
  cashShifts     CashShift[]
  stockMovements StockMovement[]
  stockReceipts  StockReceipt[]
  equipment      Equipment[]
}

model Role {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  isSystem  Boolean   @default(false)

  users       User[]
  permissions RolePermission[]
}

model Permission {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  code      String    @unique // например orders.view
  label     String
  group     String?

  roles RolePermission[]
}

model RolePermission {
  // --- синхронизация ---
  updatedAt    DateTime   @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  // --- синхронизация ---
  updatedAt    DateTime   @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  roleId       String?
  role         Role?      @relation(fields: [roleId], references: [id])
  login        String
  passwordHash String
  pinHash      String? // PIN кассира (bcrypt) для быстрого входа на кассе
  fullName     String
  phone        String?
  position     String? // должность
  salaryType   SalaryType @default(MONTHLY)
  rate         Decimal    @default(0) @db.Decimal(12, 2) // оклад или ставка/час
  isActive     Boolean    @default(true)
  // Версия токена: инкремент отзывает все ранее выданные JWT (смена пароля,
  // «выйти на всех устройствах»). Guard/me() сверяют версию из токена с этим
  // полем; старые токены без версии считаются 0 (обратная совместимость). (P1-8)
  tokenVersion Int        @default(0)
  createdAt    DateTime   @default(now())

  ordersCreated  Order[]          @relation("OrderCreatedBy")
  ordersAssigned Order[]          @relation("OrderAssignedTo")
  ordersDesigned Order[]          @relation("OrderDesigner")
  ordersOperated Order[]          @relation("OrderOperator")
  tasksCreated   Task[]           @relation("TaskCreatedBy")
  tasksAssigned  Task[]           @relation("TaskAssignedTo")
  payments       Payment[]
  stockMovements StockMovement[]
  cashShifts     CashShift[]
  productionJobs ProductionJob[]  @relation("ProductionAssignee")
  designProofs   DesignProof[]    @relation("DesignProofAssignee")
  workTime       WorkTimeRecord[]
  advances       SalaryAdvance[]
  salaryRecords  SalaryRecord[]

  @@unique([companyId, login])
}

// ======================= КЛИЕНТЫ =======================

model Client {
  id        String     @id @default(uuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  fullName  String?
  phone     String
  type      ClientType @default(INDIVIDUAL)
  email     String?
  address   String?
  inn         String?
  discount    Decimal    @default(0) @db.Decimal(5, 2) // скидка, %
  creditLimit Decimal    @default(0) @db.Decimal(12, 2) // кредитный лимит (0 = без лимита)
  bonusPoints Decimal    @default(0) @db.Decimal(12, 2) // накопленные бонусы
  note        String?
  createdAt   DateTime   @default(now())
  // --- синхронизация ---
  updatedAt DateTime   @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?

  orders     Order[]
  debts      ClientDebt[]
  quotes     Quote[]
  files      ClientFile[]
  complaints Complaint[]

  @@index([companyId, phone])
  @@index([companyId, updatedAt])
}

model Complaint {
  // --- синхронизация ---
  updatedAt   DateTime        @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
  id          String          @id @default(uuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  orderId     String?
  order       Order?          @relation(fields: [orderId], references: [id])
  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id])
  title       String
  description String?
  status      ComplaintStatus @default(OPEN)
  resolution  String? // решение
  createdById String?
  createdAt   DateTime        @default(now())

  @@index([companyId, status])
}

model PromoCode {
  // --- синхронизация ---
  updatedAt    DateTime     @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String       @id @default(uuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  code         String
  discountType DiscountType @default(PERCENT)
  value        Decimal      @db.Decimal(12, 2) // % или абсолютная сумма
  maxUses      Int? // null = без ограничения
  usedCount    Int          @default(0)
  validUntil   DateTime?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  @@unique([companyId, code])
}

model ClientFile {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileName  String?
  type      String?
  createdAt DateTime  @default(now())
}

// ======================= УСЛУГИ =======================

model ServiceCategory {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)

  // Подкатегории услуг (напр. «Печать» → «Визитки», «Баннеры»). null — верхний уровень.
  parentId String?
  parent   ServiceCategory?  @relation("ServiceCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ServiceCategory[] @relation("ServiceCategoryTree")

  services Service[]

  @@index([parentId])
}

model Service {
  // --- синхронизация ---
  updatedAt       DateTime         @default(now()) @updatedAt
  deletedAt       DateTime?
  syncNode        String?
  id              String           @id @default(uuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  categoryId      String?
  category        ServiceCategory? @relation(fields: [categoryId], references: [id])
  name            String
  pricingType     PricingType      @default(FIXED)
  basePrice       Decimal          @default(0) @db.Decimal(12, 2)
  costPrice       Decimal          @default(0) @db.Decimal(12, 2) // себестоимость (для прибыли)
  leadTimeMin     Int? // время выполнения, минут
  designSurcharge Decimal          @default(0) @db.Decimal(12, 2)
  minQuantity     Int              @default(1)
  imageUrl        String? // фото услуги (путь /uploads/...)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())

  priceTiers ServicePriceTier[]
  sizes      ServiceSize[]
  options    ServiceOption[]
  materials  ServiceMaterial[]
  orderItems OrderItem[]
}

// Норма расхода материала на единицу услуги (спецификация / BOM).
// Используется для авто-списания со склада при выполнении производства.
model ServiceMaterial {
  // --- синхронизация ---
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String    @id @default(uuid())
  serviceId  String
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  qtyPerUnit Decimal   @default(0) @db.Decimal(12, 3) // расход на 1 единицу услуги

  @@unique([serviceId, productId])
}

model ServicePriceTier {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  minQty    Int
  maxQty    Int?
  price     Decimal   @db.Decimal(12, 2)
}

model ServiceSize {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  serviceId String
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  label     String // например 10x15, A4
  price     Decimal   @db.Decimal(12, 2)
}

model ServiceOption {
  // --- синхронизация ---
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?
  syncNode      String?
  id            String    @id @default(uuid())
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name          String // тип бумаги, срочность
  priceModifier Decimal   @default(0) @db.Decimal(12, 2)
}

// ======================= ТОВАРЫ И СКЛАД =======================

model ProductCategory {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  isDefault Boolean   @default(false)

  // Подкатегории: напр. «Сувениры» → «Кружки», «Кепки». parentId = null — верхний уровень.
  parentId String?
  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("ProductCategoryTree")

  products Product[]

  @@index([parentId])
}

model Unit {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String // штука, рулон, метр квадратный
  shortName String // шт, рул, м²
  isDefault Boolean @default(false)

  products Product[]
}

model Product {
  // --- синхронизация ---
  updatedAt  DateTime         @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String           @id @default(uuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id])
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  unitId     String?
  unit       Unit?            @relation(fields: [unitId], references: [id])
  name          String
  salePrice     Decimal       @default(0) @db.Decimal(12, 2)
  purchasePrice Decimal       @default(0) @db.Decimal(12, 2) // закупочная цена / себестоимость (для отчёта прибыли)
  minStock      Decimal       @default(0) @db.Decimal(12, 3) // порог оповещения
  barcode    String?
  sku        String? // артикул
  size       String? // размер (напр. 610 x 860 мм)
  weight     String? // вес (напр. 2.5 кг)
  imageUrl   String? // фото товара (путь /uploads/...)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())

  stock            Stock[]
  movements        StockMovement[]
  orderItems       OrderItem[]
  receiptItems     StockReceiptItem[]
  serviceMaterials ServiceMaterial[]
  barcodeAliases   ProductBarcodeAlias[]
}

// Доп. штрихкоды товара (один товар = несколько ШК)
model ProductBarcodeAlias {
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcode   String    @unique
  createdAt DateTime  @default(now())

  @@index([productId])
}

model Stock {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id])
  quantity  Decimal   @default(0) @db.Decimal(12, 3)

  @@unique([productId, branchId])
}

model StockMovement {
  // --- синхронизация ---
  updatedAt DateTime          @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String            @id @default(uuid())
  companyId String
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  branchId  String?
  branch    Branch?           @relation(fields: [branchId], references: [id])
  type      StockMovementType
  quantity  Decimal           @db.Decimal(12, 3)
  beforeQty Decimal?          @db.Decimal(12, 3) // остаток до движения
  afterQty  Decimal?          @db.Decimal(12, 3) // остаток после движения
  reason    String?
  orderId   String?
  order     Order?            @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?             @relation(fields: [userId], references: [id])
  createdAt DateTime          @default(now())
}

model Supplier {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  phone     String?
  inn       String?
  note      String?
  debt      Decimal   @default(0) @db.Decimal(12, 2) // наш долг поставщику

  receipts StockReceipt[]
  payments SupplierPayment[]
}

// Оплата долга поставщику
model SupplierPayment {
  // --- синхронизация ---
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String    @id @default(uuid())
  companyId  String
  supplierId String
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  amount     Decimal   @db.Decimal(12, 2)
  note       String?
  userId     String?
  createdAt  DateTime  @default(now())

  @@index([supplierId])
}

model StockReceipt {
  // --- синхронизация ---
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?
  syncNode   String?
  id         String    @id @default(uuid())
  companyId  String
  number     String? // PRIH-<узел>-год-NNNN
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  branchId   String?
  branch     Branch?   @relation(fields: [branchId], references: [id])
  date       DateTime  @default(now())
  note       String?
  total         Decimal              @default(0) @db.Decimal(12, 2) // сумма приёмки
  paidAmount    Decimal              @default(0) @db.Decimal(12, 2) // сколько оплачено поставщику
  paymentStatus ReceiptPaymentStatus @default(PAID)
  dueDate       DateTime? // срок оплаты долга поставщику (если приняли частично/в долг)

  items StockReceiptItem[]
}

model StockReceiptItem {
  // --- синхронизация ---
  updatedAt DateTime     @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String       @id @default(uuid())
  receiptId String
  receipt   StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Decimal      @db.Decimal(12, 3)
  cost      Decimal      @default(0) @db.Decimal(12, 2) // закупочная цена за единицу
  salePrice Decimal?     @db.Decimal(12, 2) // цена продажи, заданная при приёмке
}

// Заявка на закупку (что нужно докупить). Хранится как снимок для печати/доказательства:
// «какого числа и что заказывали». Номер ЗАК-<узел>-год-NNNN.
model PurchaseRequest {
  // --- синхронизация ---
  updatedAt    DateTime  @default(now()) @updatedAt
  deletedAt    DateTime?
  syncNode     String?
  id           String    @id @default(uuid())
  companyId    String
  number       String? // ЗАК-<узел>-год-NNNN
  supplierName String? // снимок названия поставщика (необязательно)
  note         String?
  items        Json // [{productId,name,unit,stock,minStock,quantity}]
  totalQty     Decimal   @default(0) @db.Decimal(12, 3)
  createdById  String?
  createdAt    DateTime  @default(now())

  @@index([companyId])
}

// Отложенный чек (касса) — корзина сохранена, чтобы вернуться позже
model HeldSale {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  branchId  String?
  userId    String?
  label     String? // имя/метка чека
  note      String?
  items     Json // снимок корзины
  total     Decimal   @default(0) @db.Decimal(12, 2)
  createdAt DateTime  @default(now())

  @@index([companyId])
}

// Возврат по чеку/заказу
model Return {
  // --- синхронизация ---
  updatedAt DateTime       @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String         @id @default(uuid())
  companyId String
  orderId   String? // исходный заказ/чек
  branchId  String?
  clientId  String?
  number    String? // VOZ-<узел>-год-NNNN
  reason    String?
  amount    Decimal        @default(0) @db.Decimal(12, 2)
  method    PaymentMethod? // как вернули деньги
  items     Json // что вернули
  userId    String?
  createdAt DateTime       @default(now())

  @@index([companyId])
  @@index([orderId])
}

// Атомарный счётчик номеров документов по типу (ORDER/POS/VOZ/PRIH/SMENA/QUOTE...).
// Инкремент делается через INSERT ... ON CONFLICT DO UPDATE RETURNING — безопасно
// при одновременной работе многих кассиров/узлов (никаких одинаковых номеров).
model DocumentCounter {
  id        String @id @default(uuid())
  companyId String
  type      String
  value     Int    @default(0)

  @@unique([companyId, type])
}

// Списание со склада (бой/брак/порча) — с причиной и себестоимостью
model WriteOff {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  branchId  String?
  productId String
  quantity  Decimal   @db.Decimal(12, 3)
  cost      Decimal   @default(0) @db.Decimal(12, 2) // себестоимость списанного
  reason    String?
  userId    String?
  createdAt DateTime  @default(now())

  @@index([companyId])
  @@index([productId])
}

// ======================= ЗАКАЗЫ =======================

model Order {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  orderNumber    String
  receiptNumber  String? // POS-<узел>-год-NNNNN (для быстрых продаж)
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  orderType      OrderType
  status         OrderStatus   @default(ACCEPTED)
  paymentStatus  PaymentStatus @default(UNPAID)
  assignedUserId String?
  assignedUser   User?         @relation("OrderAssignedTo", fields: [assignedUserId], references: [id])
  createdById    String?
  createdBy      User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  designerId     String?
  designer       User?         @relation("OrderDesigner", fields: [designerId], references: [id])
  operatorId     String?
  operator       User?         @relation("OrderOperator", fields: [operatorId], references: [id])
  format         String? // формат: A4, A3, баннер 1x2м...
  colorMode      String? // цветность: цветной / ч-б
  urgency        OrderUrgency  @default(NORMAL)
  deadline       DateTime?
  total          Decimal       @default(0) @db.Decimal(12, 2)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(12, 2)
  returnedTotal  Decimal       @default(0) @db.Decimal(12, 2) // сумма возвращённых товаров (контр-выручка)
  returnedCost   Decimal       @default(0) @db.Decimal(12, 2) // себестоимость возвращённого
  debtDueDate    DateTime? // срок погашения долга (для напоминаний о просрочке)
  note           String?
  idempotencyKey String?       @unique // защита от двойной продажи (POS)
  createdAt      DateTime      @default(now())
  // --- синхронизация ---
  updatedAt      DateTime      @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?

  items          OrderItem[]
  repairDetail   OrderRepairDetail?
  recoveryDetail OrderRecoveryDetail?
  files          OrderFile[]
  payments       Payment[]
  debts          ClientDebt[]
  tasks          Task[]
  stockMovements StockMovement[]
  productionJobs ProductionJob[]
  proofs         DesignProof[]
  statusHistory  OrderStatusHistory[]
  complaints     Complaint[]

  @@unique([companyId, orderNumber])
  @@index([companyId, updatedAt])
}

model OrderStatusHistory {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  userId    String?
  reason    String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType    ItemType
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal   @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  unitCost    Decimal   @default(0) @db.Decimal(12, 2) // себестоимость за единицу (снимок)
  options     Json? // выбранные опции/размер/тип бумаги
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
  lineCost    Decimal   @default(0) @db.Decimal(12, 2) // себестоимость строки
  // --- синхронизация ---
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
}

model OrderRepairDetail {
  // --- синхронизация ---
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
  id          String    @id @default(uuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deviceModel String?
  problem     String?
  diagnosis   String?
}

model OrderRecoveryDetail {
  // --- синхронизация ---
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?
  syncNode      String?
  id            String    @id @default(uuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deviceType    String? // HDD, SSD, USB, карта памяти
  mediaModel    String?
  whatToRecover String?
}

model OrderFile {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileName  String?
  type      String?
  createdAt DateTime  @default(now())
}

// ======================= КАССА И ДЕНЬГИ =======================

model CashShift {
  // --- синхронизация ---
  updatedAt      DateTime  @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String    @id @default(uuid())
  companyId      String
  number         String? // SMENA-<узел>-год-NNNN
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)

  payments  Payment[]
  movements CashMovement[]
}

model Payment {
  id        String        @id @default(uuid())
  companyId String
  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id])
  shiftId   String?
  shift     CashShift?    @relation(fields: [shiftId], references: [id])
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  createdAt DateTime      @default(now())
  // --- синхронизация ---
  updatedAt DateTime      @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?

  @@index([companyId, updatedAt])
}

model CashMovement {
  // --- синхронизация ---
  updatedAt DateTime   @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String     @id @default(uuid())
  companyId String
  shiftId   String?
  shift     CashShift? @relation(fields: [shiftId], references: [id])
  type      String // IN / OUT
  amount    Decimal    @db.Decimal(12, 2)
  category  String? // категория расхода/прихода (аренда, зарплата, материалы…)
  reason    String?
  createdAt DateTime   @default(now())
}

model ClientDebt {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  orderId   String?
  order     Order?    @relation(fields: [orderId], references: [id])
  amount    Decimal   @db.Decimal(12, 2)
  dueDate   DateTime?
  isClosed  Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// ======================= ЗАДАЧИ =======================

model Task {
  // --- синхронизация ---
  updatedAt      DateTime   @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String     @id @default(uuid())
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id])
  title          String
  description    String?
  clientPhone    String?
  orderId        String?
  order          Order?     @relation(fields: [orderId], references: [id])
  assignedUserId String?
  assignedUser   User?      @relation("TaskAssignedTo", fields: [assignedUserId], references: [id])
  createdById    String?
  createdBy      User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  dueDate        DateTime?
  status         TaskStatus @default(NEW)
  priority       Int        @default(0)
  createdAt      DateTime   @default(now())
}

// ======================= ПРОИЗВОДСТВО =======================

model ProductionJob {
  // --- синхронизация ---
  updatedAt      DateTime         @default(now()) @updatedAt
  deletedAt      DateTime?
  syncNode       String?
  id             String           @id @default(uuid())
  companyId      String
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         ProductionStatus @default(PENDING)
  assignedUserId String?
  assignedUser   User?            @relation("ProductionAssignee", fields: [assignedUserId], references: [id])
  printer        String? // назначенный принтер/станок (текстом, для совместимости)
  equipmentId    String?
  equipment      Equipment?       @relation(fields: [equipmentId], references: [id])
  priority       Int              @default(0)
  note           String?
  defectReason   String? // причина брака/переделки
  resultPhotoUrl String? // фото готового результата
  materialsWrittenOff Boolean     @default(false) // материалы уже списаны
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([companyId, status])
}

// ======================= ОБОРУДОВАНИЕ =======================

model Equipment {
  // --- синхронизация ---
  updatedAt DateTime        @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String          @id @default(uuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?         @relation(fields: [branchId], references: [id])
  name      String
  type      String? // принтер, плоттер, ламинатор, резак, термопресс…
  model     String? // модель / производитель
  serial    String? // серийный / инвентарный номер
  status    EquipmentStatus @default(ACTIVE)
  note      String?
  createdAt DateTime        @default(now())

  productionJobs ProductionJob[]

  @@index([companyId])
}

// ======================= КОММЕРЧЕСКИЕ ПРЕДЛОЖЕНИЯ (КП) =======================

model Quote {
  // --- синхронизация ---
  updatedAt        DateTime    @default(now()) @updatedAt
  deletedAt        DateTime?
  syncNode         String?
  id               String      @id @default(uuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  clientId         String?
  client           Client?     @relation(fields: [clientId], references: [id])
  number           String
  status           QuoteStatus @default(DRAFT)
  title            String?
  note             String?
  total            Decimal     @default(0) @db.Decimal(12, 2)
  validUntil       DateTime?
  convertedOrderId String? // id заказа, если КП принято и превращено в заказ
  createdAt        DateTime    @default(now())

  items QuoteItem[]

  @@unique([companyId, number])
  @@index([companyId, updatedAt])
}

model QuoteItem {
  // --- синхронизация ---
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  syncNode    String?
  id          String    @id @default(uuid())
  quoteId     String
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemType    ItemType
  serviceId   String?
  productId   String?
  description String?
  quantity    Decimal   @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
}

// ======================= ДИЗАЙН-МАКЕТЫ =======================

model DesignProof {
  // --- синхронизация ---
  deletedAt      DateTime?
  syncNode       String?
  id             String      @id @default(uuid())
  companyId      String
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title          String?
  version        Int         @default(1)
  status         ProofStatus @default(TODO)
  fileUrl        String?
  fileName       String?
  comment        String? // комментарий клиента/правки
  checklist      Json? // чек-лист перед печатью { cmyk: true, bleed: true, ... }
  assignedUserId String?
  assignedUser   User?       @relation("DesignProofAssignee", fields: [assignedUserId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyId, status])
}

// ======================= ЗАРПЛАТА =======================

model WorkTimeRecord {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @default(now())
  hours     Decimal   @db.Decimal(6, 2)
  note      String?

  @@index([companyId, userId])
}

model PayrollPeriod {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean   @default(false)
  createdAt DateTime  @default(now())

  records SalaryRecord[]
}

model SalaryAdvance {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal   @db.Decimal(12, 2)
  date      DateTime  @default(now())
  note      String?
}

model SalaryRecord {
  // --- синхронизация ---
  updatedAt DateTime      @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String        @id @default(uuid())
  companyId String
  periodId  String
  period    PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  base      Decimal       @default(0) @db.Decimal(12, 2)
  bonus     Decimal       @default(0) @db.Decimal(12, 2)
  advance   Decimal       @default(0) @db.Decimal(12, 2)
  deduction Decimal       @default(0) @db.Decimal(12, 2)
  total     Decimal       @default(0) @db.Decimal(12, 2)
  isPaid    Boolean       @default(false)

  @@unique([periodId, userId])
}

// ======================= СИНХРОНИЗАЦИЯ =======================

// На каком моменте остановилась синхронизация с другим узлом.
// peer — идентификатор другого узла (например "cloud" или "branch-1").
model SyncCursor {
  id         String   @id @default(uuid())
  peer       String   @unique
  lastPullAt DateTime @default(now()) // последняя забранная метка времени
  updatedAt  DateTime @updatedAt
}

// ======================= СИСТЕМНОЕ =======================

model AuditLog {
  id        String   @id @default(uuid())
  companyId String?
  userId    String?
  action    String
  entity    String?
  entityId  String?
  data      Json?
  createdAt DateTime @default(now())
}

model Setting {
  // --- синхронизация ---
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  syncNode  String?
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  key       String
  value     String?

  @@unique([companyId, key])
}
